load('ecg_signal.mat')

signal = ecg_signal;

figure;
plot(t, signal);
title('ECG Signal');
xlabel('Time (s)');
ylabel('Amplitude');

N = length(signal);

f = (0:N-1)*(Fs/N);

Y = abs(fft(signal));

figure;
plot(f,Y);
title('FFT Spectrum');
xlabel('Frequency (Hz)');
ylabel('Magnitude');

fc = 20;

[b,a] = butter(4,fc/(Fs/2));

filtered = filtfilt(b,a,signal);

figure;
plot(t,signal);
hold on;
plot(t,filtered,'LineWidth',2);

legend('Original','Filtered');

title('Filtered ECG');

snr_before = snr(signal);
snr_after = snr(filtered);

fprintf('SNR Before: %.2f dB\n', snr_before);
fprintf('SNR After : %.2f dB\n', snr_after);